# ── Server Configuration ─────────────────────────────────────────────────────
NODE_ENV=production
SERVER_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskmanager

# ── Database (Docker Compose) ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskmanager

# ── Client Configuration ──────────────────────────────────────────────────────
CLIENT_PORT=5173
VITE_API_URL=http://localhost:3001

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Comma-separated list of allowed CORS origins (your Vercel frontend URL).
# localhost origins are always allowed in development.
# Required on Render when frontend is on Vercel (exact URL, no trailing slash).
# Example: ALLOWED_ORIGINS=https://task-manager-app-liard-ten.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# Optional shorthand (same value as your Vercel URL if you only have one frontend):
# FRONTEND_URL=https://your-app.vercel.app

# Rate limiting: 100 requests per 15 minutes per IP (configured in app.js)
# No env override needed unless you want to customise the window/max values.
